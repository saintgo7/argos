# argos.abada.co.kr production environment template.
# Copy to /data/abada-co-kr/argos-abada-co-kr/argos.abada.co.kr/.env on the
# server (chmod 600) and fill in real values. NEVER commit the real file.

# ─────────────────────────────────────────
# Image pin (optional; defaults to :latest)
# Deploy workflow sets this to a specific short SHA for atomic releases.
# ─────────────────────────────────────────
TAG=latest

# ─────────────────────────────────────────
# PostgreSQL (used by `postgres` service)
# ─────────────────────────────────────────
POSTGRES_USER=argos
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_-hex_32
POSTGRES_DB=argos

# ─────────────────────────────────────────
# Prisma (used by `web` service)
# Hostname is the docker-compose service name.
# Password MUST match POSTGRES_PASSWORD above.
# ─────────────────────────────────────────
DATABASE_URL=postgresql://argos:CHANGE_ME_SAME_AS_POSTGRES_PASSWORD@postgres:5432/argos?schema=public
DIRECT_URL=postgresql://argos:CHANGE_ME_SAME_AS_POSTGRES_PASSWORD@postgres:5432/argos?schema=public

# ─────────────────────────────────────────
# Auth secrets (min 32 chars each)
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────
AUTH_SECRET=CHANGE_ME_32_CHAR_RANDOM_STRING_HERE_____________________
JWT_SECRET=CHANGE_ME_32_CHAR_RANDOM_STRING_HERE______________________

# ─────────────────────────────────────────
# NextAuth v5 — reverse-proxy trust
# Without these, auth.js rejects the Host header and every authenticated
# API call returns 401 ("UntrustedHost"). Required behind Cloudflare
# Tunnel + nginx because the container sees Host as 0.0.0.0:3000.
# ─────────────────────────────────────────
AUTH_TRUST_HOST=true
AUTH_URL=https://argos.abada.co.kr

# ─────────────────────────────────────────
# Public site URL (must match Cloudflare Tunnel hostname)
# ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://argos.abada.co.kr
