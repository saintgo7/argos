# Dependencies and build output (rebuilt inside the image)
**/node_modules
**/.next
**/dist
**/.turbo

# Local env files (must NEVER be baked into images)
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.*.local

# Git + editor
.git
.gitignore
.github
.vscode
.idea

# OS cruft
.DS_Store
Thumbs.db

# Test + coverage artifacts
**/coverage
**/.nyc_output

# Docs and harness output (not needed at runtime)
docs
iterations
tasks
persuasion-data
prompts
scripts
cc-test

# Compose files (not needed inside image)
docker-compose*.yml
Dockerfile
.dockerignore

# Claude/Argos config
.claude
.argos

# README (not runtime-required)
README.md
DEPLOYMENT.md
